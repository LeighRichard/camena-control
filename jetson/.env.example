# 相机位置控制系统 - 环境变量配置示例
# 复制此文件为 .env 并修改配置

# ==================== 安全配置 ====================
# JWT 密钥（生产环境必须设置）
CAMERA_CONTROL_SECRET_KEY=your-secure-secret-key-here

# ==================== 相机配置 ====================
# 是否启用相机
CAMERA_ENABLED=true

# 相机类型: auto, realsense, orbbec
CAMERA_TYPE=auto

# 相机分辨率
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720
CAMERA_FPS=30

# ==================== 串口通信配置 ====================
# 串口设备路径
# Linux: /dev/ttyUSB0 或 /dev/ttyACM0
# Windows: COM3
COMM_PORT=/dev/ttyUSB0

# 波特率
COMM_BAUDRATE=115200

# ==================== Web 服务配置 ====================
# 服务端口
WEB_PORT=8080
WEB_HOST=0.0.0.0

# 是否启用身份认证
WEB_AUTH_ENABLED=false

# ==================== 人脸识别配置 ====================
# 人脸数据库路径
FACE_DB_PATH=face_database

# ==================== 日志配置 ====================
# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ==================== 开发配置 ====================
# 调试模式（生产环境设为 false）
DEBUG_MODE=false

# Flask 调试模式
FLASK_ENV=production
